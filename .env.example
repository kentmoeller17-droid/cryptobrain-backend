# B.R.A.I.N. – einfache Render-Version ohne Mail-Verifizierung
APP_TITLE=B.R.A.I.N.
HOST=127.0.0.1
PORT=5100
AUTO_OPEN_BROWSER=1
REQUEST_TIMEOUT=15
SECRET_KEY=brain-v106-render-login-secret
SESSION_COOKIE_NAME=brain_session

# AI / Brain live
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant

# Optional: Read-only Marktanbindung
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Speicher
APP_DB_PATH=superbrain_workspace_v106.db
APP_BACKUP_DIR=backups
APP_CLOUD_DIR=cloud_store
WORKSPACE_DIR=workspace

# Render persistent disk mount, z. B. /var/data
APP_STORAGE_ROOT=

# Streamlit
STREAMLIT_START_PORT=8510

# Nur fuer Kent / Kern-OP
CORE_SURGERY_CONFIRMATION=ICH BIN HERRCHEN

# Render / Session
APP_EXTERNAL_URL=
TRUST_PROXY=0
FORCE_HTTPS=0
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_HTTPONLY=1
SESSION_REFRESH_EACH_REQUEST=1
PERMANENT_SESSION_LIFETIME_DAYS=30
SESSION_COOKIE_DOMAIN=
